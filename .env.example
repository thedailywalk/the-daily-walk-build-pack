# =============================================================================
# The Daily Walk — environment variables
# Copy this file to ".env.local" and fill in real values. NEVER commit secrets.
# The site runs without any of these (subscribe form works in dev mode); add the
# Beehiiv keys to write to the real list and wire the upgrade links.
# =============================================================================

# Public site URL (used for SEO/canonical/OG). No trailing slash.
APP_URL=https://thedailywalknewsletter.com

# --- Beehiiv (server-side; keep secret) -------------------------------------
# Create an API key in Beehiiv: Settings → Integrations → API.
# Publication id looks like "pub_xxxxxxxx-xxxx-...".
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# --- Beehiiv hosted pages (public; safe to expose) --------------------------
# Used as fallbacks / deep-links from the site. Leave blank to hide the links.
NEXT_PUBLIC_BEEHIIV_SUBSCRIBE_URL=
NEXT_PUBLIC_BEEHIIV_PREMIUM_URL=
NEXT_PUBLIC_BEEHIIV_PATRON_URL=
NEXT_PUBLIC_BEEHIIV_ARCHIVE_URL=
NEXT_PUBLIC_BEEHIIV_MANAGE_URL=

# --- Community (optional) ----------------------------------------------------
NEXT_PUBLIC_COMMUNITY_URL=

# --- Donations (public; safe to expose) --------------------------------------
# GoFundMe campaign link for the "Give on GoFundMe" button. Blank = "soon" note.
NEXT_PUBLIC_GOFUNDME_URL=
# Givebutter — powers the "Give" button + the /give donation page.
# See docs/GIVEBUTTER-SETUP.md for the step-by-step. After you create your
# campaign, fill these in (all three are PUBLIC / safe in the browser):
#   URL:        your campaign's public link, e.g. https://givebutter.com/your-slug
#   WIDGET_ID:  the embed widget ID (shows the donation FORM on /give)
#   ACCOUNT_ID: your Givebutter account ID (used by the embed script)
NEXT_PUBLIC_GIVEBUTTER_URL=
NEXT_PUBLIC_GIVEBUTTER_WIDGET_ID=
NEXT_PUBLIC_GIVEBUTTER_ACCOUNT_ID=

# --- Supabase (member sign-in + database) -----------------------------------
# From Supabase → Project Settings → Data API / API Keys.
# URL and anon key are PUBLIC (safe in the browser). Service role key is SECRET.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Needed for the Devotional Prep admin to save/publish devotionals server-side
# (keep secret, do not expose to the browser):
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin access ------------------------------------------------------------
# Comma-separated emails allowed into the admin area (Devotional Prep, etc.).
# The owner (thedailywalknewsletter@gmail.com) is always included.
ADMIN_EMAILS=

# --- Weekly Featured Video (Daily Wonders) -----------------------------------
# Free YouTube Data API v3 key. Lets the admin studio read each candidate's REAL
# embeddable flag, license, privacy, and channel so it can show what's genuinely
# safe to feature. Get one at: Google Cloud Console -> APIs & Services -> enable
# "YouTube Data API v3" -> Credentials -> Create API key. (Server-side only.)
YOUTUBE_API_KEY=

# --- Cron (optional) ---------------------------------------------------------
# Protects the scheduled jobs (good-news refresh + daily devotional auto-draft).
# Set any long random string; Vercel Cron sends it automatically. If blank, the
# jobs still run but are unauthenticated (they only seed drafts / bust caches).
CRON_SECRET=

# --- Anthropic / Claude (optional but recommended) ---------------------------
# Powers the deep, personal "feels hand-written" workbook suggestions and the
# Pathlight Bible guide. WITHOUT it, the workbook still suggests edits using a
# simpler heuristic draft. Get a key at https://console.anthropic.com -> API Keys.
# Server-side only — never exposed to the browser.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-haiku-4-5 — fast & inexpensive).
# WORKBOOK_MODEL=claude-haiku-4-5-20251001
